def get_weather_temp():
    url = "https://api.open-meteo.com/v1/forecast?latitude=51.5&longitude=-0.12&current_weather=true"
    try:
        response = requests.get(url)
        data = response.json()
        return data["current_weather"]["temperature"]
    except:
        return None

def temp_to_categories(temp):
    if temp is None:
        return []
    elif temp <= 5:
        return ["coat", "hoodie/jumper"]
    elif temp <= 12:
        return ["jacket", "hoodie/jumper", "trousers"]
    elif temp <= 18:
        return ["hoodie/jumper", "trousers", "jogger"]
    elif temp <= 24:
        return ["t-shirt / shirt", "trousers"]
    else:
        return ["t-shirt / shirt", "shorts"]

def recommend_clothes(username, top_n=5):
    with open("user.json", "r") as file:
        user_data = json.load(file)
    clothes = user_data[username]["clothes"]
    temp = get_weather_temp()
    suitable_categories = temp_to_categories(temp)
    scored = []
    for item in clothes:
        if not item["isclean"]:
            continue
        score = 0
        times_worn = item["times_worn"]
        score += max(0, 10 - times_worn)
        if suitable_categories and item["category"] in suitable_categories:
            score += 15
        scored.append((item, score, temp))
    scored.sort(key=lambda x: x[1], reverse=True)
    return scored[:top_n], temp



def main_page(username, windowtype):
