class ClothingItem:
    def __init__(self, clothing_id: int, name: str, colour: str, category: str, url: str, isclean: bool = True, times_worn: int = 0):
        self.clothing_id = clothing_id
        self.name = name
        self.colour = colour
        self.category = category
        self.url = url
        self.isclean = isclean
        self.times_worn = times_worn

    def display(self):
       print("clothing item")
       print(f"ID:{self.clothing_id}")
       print(f"Name:{self.name}")
       print(f"colour:{self.colour}")
       print(f"category:{self.category}")
       print(f"imageID:{self.url}")
       print(f"is clean?:{self.isclean}")
       print(f"times worn?:{self.times_worn}")
    
    def makejson(self):
       return{
          "clothing_ID":self.clothing_id,
          "name":self.name,
          "colour":self.colour,
          "category":self.category,
          "imageurl":self.url,
          "isclean":self.isclean,
          "times_worn":self.times_worn
       }


         
