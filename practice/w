    welcomeMessageLabel.pack(pady=20)

    
    # CHANGED — replaced the old "function in progress" button with a labelframe
    # that holds the recommendation system
    rec_frame = tkinter.LabelFrame(frame, text="today's recommendation", bg="#6C6565", fg="white", font=("Arial", 11))
    rec_frame.grid(row=1, column=0, columnspan=2, pady=15, padx=10, sticky="nesw")

    rec_label = tkinter.Label(rec_frame, text="press to get recommendation", fg="white", bg="#6C6565", font=("Arial", 13))
    rec_label.grid(row=0, column=0, columnspan=2, pady=10, padx=10)

    temp_label = tkinter.Label(rec_frame, text="", fg="white", bg="#6C6565", font=("Arial", 11))
    temp_label.grid(row=1, column=0, columnspan=2)

    # CHANGED — queue dictionary to track which recommendation we are on
    queue = {"items": [], "index": 0}

    def load_recommendations():
        result, temp = recommend_clothes(username)
        queue["items"] = [item for item, score, _ in result]
        queue["index"] = 0
        temp_text = f"{temp} degrees outside" if temp is not None else "weather not available"
        temp_label.config(text=temp_text)
        show_next()

    # CHANGED — show_next displays the current item in the queue
    def show_next():
        if queue["index"] >= len(queue["items"]):
            rec_label.config(text="no recommendations left")
            # FIXED — was text="disabled" which just wrote the word on the button
            # state="disabled" actually disables the button
            yes_button.config(state="disabled")
            no_button.config(state="disabled")
            return
        item = queue["items"][queue["index"]]
        # FIXED — was using f"{item["name"]}" with double quotes inside double quotes
        # which breaks the string, switched to single quotes inside
        rec_label.config(text=f"{item['name']} - {item['category']} ({item['colour']})")
        yes_button.config(state="normal")
        no_button.config(state="normal")

    # FIXED — wear_it was accidentally indented inside show_next
    # moved it out to the same level so yes_button can actually reach it
    def wear_it():
        if queue["index"] >= len(queue["items"]):
            return
        item = queue["items"][queue["index"]]
        with open("user.json", "r") as file:
            user_data = json.load(file)
        for c in user_data[username]["clothes"]:
            if c["clothing_ID"] == item["clothing_ID"]:
                c["times_worn"] += 1
                break
        with open("user.json", "w") as file:
            json.dump(user_data, file, indent=4)
        queue["index"] += 1
        show_next()

    def skip_it():
        queue["index"] += 1
        show_next()

    get_rec_button = tkinter.Button(rec_frame, text="get recommendation", bg="#757474", fg="white", font=("Arial", 12), command=load_recommendations)
    get_rec_button.grid(row=2, column=0, columnspan=2, pady=8, padx=10, sticky="nesw")

    yes_button = tkinter.Button(rec_frame, text="yes, i'll wear this", bg="#00FF1A", fg="black", font=("Arial", 12), command=wear_it, state="disabled")
